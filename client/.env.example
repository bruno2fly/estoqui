# Estoqui — Environment Variables
# Copy to .env.local and fill in values. Never commit .env.local.

# ─── Client (VITE_* are exposed to the browser) ───

# Optional: Custom OpenAI API base URL (default: https://api.openai.com)
# VITE_OPENAI_BASE_URL=https://api.openai.com

# ─── Future backend (when adding Supabase/Postgres) ───

# VITE_SUPABASE_URL=https://xxx.supabase.co
# VITE_SUPABASE_ANON_KEY=your_anon_key

# Server-only (do NOT use VITE_ prefix):
# SUPABASE_SERVICE_ROLE_KEY=...
# DATABASE_URL=...
